# SmartLogParser Environment Configuration
# Copy this file to .env and fill in your values

# ── LLM Provider (choose one) ──────────────────────────────────────────────────

# Option A: Groq (cloud, easy setup for development)
GROQ_API_KEY=

# Option B: Ollama (local, used automatically in Docker — no data leaves machine)
# OLLAMA_URL=http://localhost:11434
# LLM_MODEL=llama3.2

# ── Database ───────────────────────────────────────────────────────────────────

# Supabase PostgreSQL (recommended for production)
# Get this from your Supabase project settings under Database > Connection String
# DATABASE_URL=postgresql+psycopg://postgres:[password]@db.[project].supabase.co:5432/postgres

# Local SQLite (default for development — leave empty to use SQLite)
# DATABASE_URL=sqlite:///./smartlogparser.db

# ── Upload Settings ────────────────────────────────────────────────────────────

MAX_UPLOAD_SIZE_MB=20

# ── Observability Integrations (optional) ─────────────────────────────────────

# Splunk HEC
# SPLUNK_HEC_URL=
# SPLUNK_HEC_TOKEN=

# Elasticsearch
# ELASTIC_URL=https://localhost:9200
# ELASTIC_USERNAME=elastic
# ELASTIC_PASSWORD=
# ELASTIC_INDEX=fab-logs-2026
